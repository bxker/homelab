# Terraform state (contains sensitive values)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Environment / secrets
.env
*.tfvars
!terraform.tfvars.example

# Large binaries
*.iso

# Helm dependency artifacts (ArgoCD runs `helm dependency build` itself)
kubernetes/apps/**/charts/
kubernetes/apps/**/Chart.lock
